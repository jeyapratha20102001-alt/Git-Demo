package selenium;

public class Java {

	public static void main(String[] args) {
		int n=7;
		int ft=0;
		int se=1;
		int next=0;
		
		if(n==1)
			System.out.println(ft);
		if(n==2)
			System.out.println(se);
		else {
		
		
		for (int i = 3; i <=n; i++) {
			 next=ft+se;
			
			ft=se;
			se=next;
		}
		System.out.print(next+" ");	
		}
		
	}

}
